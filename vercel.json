{
  "functions": {
    "api/*.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/admin", "destination": "/admin.html" }
  ],
  "crons": [
    {
      "path": "/api/telegram-digest",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/security?type=backup",
      "schedule": "0 20 * * *"
    }
  ]
}
